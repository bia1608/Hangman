<Window x:Class="Hangman.Views.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Utilizator Nou" Height="380" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titlu -->
            <RowDefinition Height="Auto"/>
            <!-- Campul Username -->
            <RowDefinition Height="*"/>
            <!-- Imagini predefinite + preview -->
            <RowDefinition Height="Auto"/>
            <!-- Buton browse + path afisat -->
            <RowDefinition Height="Auto"/>
            <!-- Butoane OK/Cancel -->
        </Grid.RowDefinitions>

        <!-- Titlu -->
        <TextBlock Grid.Row="0"
                   Text="Creeaza un utilizator nou"
                   FontSize="15" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Username -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Username:" Width="90" VerticalAlignment="Center"/>
            <TextBox x:Name="UsernameBox" Width="250" Height="28"
                     Padding="4,2" FontSize="13"/>
        </StackPanel>

        <!-- Imagini predefinite + preview -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <!-- Galerie imagini predefinite -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Imagini predefinite:" FontSize="12" Margin="0,0,0,5"/>
                <ListBox x:Name="PredefinedImagesList"
                         Height="150"
                         SelectionChanged="PredefinedImagesList_SelectionChanged"
                         Background="White"
                         FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,6,0,0">
                    <Button Content="&lt;&lt;" Click="PrevImage_Click" Width="45"/>
                    <Button Content="&gt;&gt;" Click="NextImage_Click" Width="45"/>
                </StackPanel>
            </StackPanel>

            <!-- Preview imagine selectata -->
            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" CornerRadius="4">
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       Margin="6"/>
            </Border>
        </Grid>

        <!-- Browse fisier imagine -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Sau alege o imagine din calculator:" FontSize="12" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Browse..." Click="BrowseImage_Click" Width="80"/>
                <TextBlock x:Name="SelectedPathText"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           FontSize="11" Foreground="#555"
                           Text="Nicio imagine selectata"
                           MaxWidth="270" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </StackPanel>

        <!-- Butoane OK / Cancel -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Creeaza" Click="Create_Click"
                    Width="90" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Content="Anuleaza" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
