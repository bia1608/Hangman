<Window x:Class="Hangman.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="231" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
        <TextBlock Text="Hangman Game"
                   FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- Modificati aceste valori cu datele voastre -->
        <TextBlock Text="Student: Danci Bianca"     FontSize="14" Margin="0,4"/>
        <TextBlock Text="Grupa:   10LF341"       FontSize="14" Margin="0,4"/>
        <TextBlock Text="Specializarea:  IA"     FontSize="14" Margin="0,4"/>

        <Button Content="OK"
                Click="OK_Click"
                Width="80" Margin="0,20,0,0"
                HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
