<Window x:Class="Hangman.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.Views" xmlns:viewmodels="clr-namespace:Hangman.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titlu -->
            <RowDefinition Height="*"/>
            <!-- Lista + imagine -->
            <RowDefinition Height="Auto"/>
            <!-- Butoane navigare imagini -->
            <RowDefinition Height="Auto"/>
            <!-- Butoane actiuni -->
        </Grid.RowDefinitions>

        <!-- Titlu -->
        <TextBlock Grid.Row="0"
                   Text="Welcome to Hangman! Enjoy this game!"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Lista utilizatori + imagine -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- Lista utilizatori -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Users}"
                     SelectedItem="{Binding SelectedUser}"
                     DisplayMemberPath="Username"
                     Background="White"
                     BorderBrush="#AAAAAA"
                     FontSize="14"
                     Margin="0,0,10,0"/>

            <!-- Imaginea utilizatorului selectat -->
            <Border Grid.Column="1"
                    BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" CornerRadius="4">
                <Image Source="{Binding SelectedUserImage}"
                       Stretch="Uniform"
                       Margin="8"
                       x:Name="UserImageControl"/>
            </Border>
        </Grid>

        <!-- Butoane actiuni -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="New User"
                    Command="{Binding NewUserCommand}"
                    Width="100"/>
            <Button Content="Delete User"
                    Command="{Binding DeleteUserCommand}"
                    Width="100"
                    IsEnabled="{Binding IsUserSelected}"/>
            <Button Content="Play"
                    Command="{Binding PlayCommand}"
                    Width="80"
                    IsEnabled="{Binding IsUserSelected}"
                    FontWeight="Bold"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="80"/>
        </StackPanel>
    </Grid>
</Window>
